# Copy this file to .env.local and fill in your Supabase project's values.
# Find them in the Supabase dashboard: Project Settings → API.
# .env.local is gitignored; .env.example is the committed template.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Public base URL of the deployed site (no trailing slash) — used for absolute
# OG/Twitter image URLs. Set to your real domain in production, e.g. https://timesheet.app
VITE_SITE_URL=http://localhost:5188
